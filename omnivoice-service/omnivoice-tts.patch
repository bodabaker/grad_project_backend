+        *tokens_out = nullptr;
+        *ref_T_out = 0;
+        return 0;
+    }
+
+    const int K = ov->pt.lm.num_audio_codebook;
+    int T = (int) codes.size() / K;
+    int32_t * buf = (int32_t *) std::malloc(codes.size() * sizeof(int32_t));
