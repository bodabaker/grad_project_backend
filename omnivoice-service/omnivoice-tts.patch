+        ov_set_error("ov_encode_ref : malloc failed");
+        *tokens_out = nullptr;
+        *ref_T_out = 0;
+        return 0;
+    }
+    std::memcpy(buf, codes.data(), codes.size() * sizeof(int32_t));
+    *tokens_out = buf;
+    *ref_T_out = T;
