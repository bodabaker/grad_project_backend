+static std::string json_get_string(const std::string & json, const std::string & key) {
+    std::string needle = "\"" + key + "\"";
+    size_t pos = json.find(needle);
+    if (pos == std::string::npos) return "";
+    pos = json.find(':', pos + needle.size());
+    if (pos == std::string::npos) return "";
+    pos = json.find('"', pos + 1);
+    if (pos == std::string::npos) return "";
+    pos++;
+    std::string val;
+    bool esc = false;
+    for (size_t i = pos; i < json.size(); i++) {
+        char c = json[i];
+        if (esc) {
+            if (c == 'n') val += '\n';
+            else if (c == 't') val += '\t';
+            else if (c == '"') val += '"';
+            else if (c == '\\') val += '\\';
+            else val += c;
+            esc = false;
+        } else if (c == '\\') {
+            esc = true;
+        } else if (c == '"') {
+            break;
+        } else {
+            val += c;
+        }
+    }
+    return val;
+}
+
+static int json_get_int(const std::string & json, const std::string & key, int def) {
+    std::string needle = "\"" + key + "\"";
+    size_t pos = json.find(needle);
+    if (pos == std::string::npos) return def;
+    pos = json.find(':', pos + needle.size());
+    if (pos == std::string::npos) return def;
+    pos++;
+    while (pos < json.size() && json[pos] == ' ') pos++;
+    if (pos >= json.size() || (json[pos] != '-' && (json[pos] < '0' || json[pos] > '9'))) return def;
+    return atoi(json.c_str() + pos);
+}
+
+static bool json_get_bool(const std::string & json, const std::string & key, bool def) {
+    std::string needle = "\"" + key + "\"";
+    size_t pos = json.find(needle);
+    if (pos == std::string::npos) return def;
+    pos = json.find(':', pos + needle.size());
+    if (pos == std::string::npos) return def;
+    pos++;
+    while (pos < json.size() && json[pos] == ' ') pos++;
+    return json.compare(pos, 4, "true") == 0;
+}
+
+static int run_server_mode(const char * model_path,
+                           const char * codec_path,
+                           bool         use_fa,
+                           bool         clamp_fp16,
+                           bool         offload_encode,
+                           bool         skip_encode,
+                           int          default_steps,
+                           uint64_t     default_seed) {
+    ov_init_params iparams;
+    ov_init_default_params(&iparams);
+    iparams.model_path     = model_path;
+    iparams.codec_path     = codec_path;
+    iparams.use_fa         = use_fa;
+    iparams.clamp_fp16     = clamp_fp16;
+    iparams.offload_encode = offload_encode;
+    iparams.skip_encode    = skip_encode;
+
+    ov_context * ov = ov_init(&iparams);
+    if (!ov) {
+        fprintf(stderr, "[Server] ERROR: ov_init failed: %s\n", ov_last_error());
+        return 1;
+    }
+
+    fprintf(stderr, "[Server] Ready. Send JSON lines on stdin.\n");
+    fprintf(stderr, "[Server] Fields: text, out, lang, instruct, steps, seed, ref_wav, ref_text, denoise, preprocess, duration, fmt\n");
+
+    std::string line;
+    int         n_req = 0;
+    std::unordered_map<std::string, CachedRef> ref_cache;
+    while (std::getline(std::cin, line)) {
+        if (line.empty()) continue;
+        n_req++;
+        fprintf(stderr, "[Server] Request %d\n", n_req);
+
+        std::string text    = json_get_string(line, "text");
+        std::string outpath = json_get_string(line, "out");
+        if (text.empty() || outpath.empty()) {
+            fprintf(stderr, "[Server] ERROR: missing \"text\" or \"out\"\n");
+            printf("ERROR\n");
+            fflush(stdout);
+            continue;
+        }
+
+        std::string lang         = json_get_string(line, "lang");
+        std::string raw_instruct = json_get_string(line, "instruct");
+        std::string ref_wav      = json_get_string(line, "ref_wav");
+        std::string ref_text_path = json_get_string(line, "ref_text");
+        int         steps        = json_get_int(line, "steps", default_steps);
+        int         seed_req     = json_get_int(line, "seed", -1);
+        bool        denoise      = json_get_bool(line, "denoise", true);
+        bool        preprocess   = json_get_bool(line, "preprocess", true);
+        float       duration_sec = (float) json_get_int(line, "duration", 0);
+        std::string fmt_str      = json_get_string(line, "fmt");
+        WavFormat   wav_fmt      = WAV_S16;
+        if (!fmt_str.empty()) {
+            audio_parse_format(fmt_str.c_str(), wav_fmt);
+        }
+
+        uint64_t seed_resolved = (seed_req < 0)
+            ? (uint64_t) std::random_device{}()
+            : (uint64_t) seed_req;
+
+        ov_tts_params params;
+        ov_tts_default_params(&params);
+        params.text              = text.c_str();
+        params.lang              = lang.c_str();
+        params.instruct          = raw_instruct.c_str();
+        params.denoise           = denoise;
+        params.preprocess_prompt = preprocess;
+        params.mg_seed           = seed_resolved;
+        params.mg_num_step       = steps;
+
+        if (duration_sec > 0.0f) {
+            params.T_override = ov_duration_sec_to_tokens(ov, duration_sec);
+        }
+
+        std::vector<float>    ref_audio_buf;
+        std::string           ref_text_str;
+        std::vector<int32_t>  cached_codes;
+        int                   cached_T = 0;
+
+        if (!ref_wav.empty()) {
+            if (ref_text_path.empty()) {
+                fprintf(stderr, "[Server] ERROR: ref_wav requires ref_text\n");
+                printf("ERROR\n");
+                fflush(stdout);
+                continue;
+            }
+
+            std::string cache_key = hash_file_head(ref_wav);
+            auto it = ref_cache.find(cache_key);
+            if (it != ref_cache.end()) {
+                cached_codes = it->second.codes;
+                cached_T = it->second.T;
+                fprintf(stderr, "[Server] Ref cache hit: %s (K*T=%d)\n", cache_key.c_str(), (int) cached_codes.size());
+                params.ref_audio_tokens = cached_codes.data();
+                params.ref_T = cached_T;
+                params.ref_text = ref_text_path.c_str();
+            } else {
+                int     n_samples = 0;
+                float * raw_samples = audio_read_mono(ref_wav.c_str(), 24000, &n_samples);
+                if (!raw_samples || n_samples <= 0) {
+                    fprintf(stderr, "[Server] ERROR: failed to load %s\n", ref_wav.c_str());
+                    printf("ERROR\n");
+                    fflush(stdout);
+                    continue;
+                }
+                ref_audio_buf.assign(raw_samples, raw_samples + n_samples);
+                free(raw_samples);
+
+                double sumsq = 0.0;
+                for (float v : ref_audio_buf) sumsq += (double) v * (double) v;
+                double ref_rms = std::sqrt(sumsq / (double) ref_audio_buf.size());
+                if (ref_rms > 0.0 && ref_rms < 0.1) {
+                    float gain = (float) (0.1 / ref_rms);
+                    for (float & v : ref_audio_buf) v *= gain;
+                }
+                if (preprocess) {
+                    remove_silence(ref_audio_buf, 24000, 200, 100, 200, -50.0);
+                }
+
+                int32_t * tokens = nullptr;
+                int       ref_T = 0;
+                int       n_encoded = ov_encode_ref(ov, ref_audio_buf.data(), (int) ref_audio_buf.size(), &tokens, &ref_T);
+                if (n_encoded <= 0 || !tokens) {
+                    fprintf(stderr, "[Server] ERROR: ov_encode_ref failed\n");
+                    printf("ERROR\n");
+                    fflush(stdout);
+                    continue;
+                }
+                cached_codes.assign(tokens, tokens + n_encoded);
+                cached_T = ref_T;
+                ov_encoded_ref_free(tokens);
+
+                ref_cache[cache_key] = {cached_codes, cached_T, (float) ref_rms};
+                fprintf(stderr, "[Server] Ref encoded and cached: %s (K=%d T=%d)\n", cache_key.c_str(), 8, cached_T);
+
+                params.ref_audio_tokens = cached_codes.data();
+                params.ref_T = cached_T;
+                params.ref_text = ref_text_path.c_str();
+            }
+        }
+
+        ov_audio audio = {};
+        if (ov_synthesize(ov, &params, &audio) != OV_STATUS_OK) {
+            fprintf(stderr, "[Server] ERROR: synthesis failed: %s\n", ov_last_error());
+            printf("ERROR\n");
+            fflush(stdout);
+            continue;
+        }
+
+        if (!audio_write_wav(outpath.c_str(), audio.samples, audio.n_samples, audio.sample_rate, wav_fmt)) {
+            fprintf(stderr, "[Server] ERROR: WAV write failed\n");
+            ov_audio_free(&audio);
+            printf("ERROR\n");
+            fflush(stdout);
+            continue;
+        }
+        fprintf(stderr, "[Server] OK: %s (%d samples, %.2f s)\n",
+                outpath.c_str(), audio.n_samples,
+                (double) audio.n_samples / (double) audio.sample_rate);
+        ov_audio_free(&audio);
+
+        printf("%s\n", outpath.c_str());
+        fflush(stdout);
+    }
+    fprintf(stderr, "[Server] Shutting down after %d requests\n", n_req);
+    ov_free(ov);
+    return 0;
+}
